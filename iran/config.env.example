# SEAMLESS Iran Agent — example config
# Copy this to config.env and fill in your values.
# install.sh will create this file automatically.

# ── Bot API connection ─────────────────────────────────────────────────────────
# Full URL of the bot's API server (the Flask app running on the foreign server)
BOT_API_URL=http://YOUR_FOREIGN_SERVER_IP:8080

# ── Registration (one-time, filled in by install.sh / register.py) ────────────
# Registration token — obtained from the bot admin panel
REGISTRATION_TOKEN=

# ── Agent identity (filled in after successful registration) ──────────────────
# DO NOT share these values — treat as secrets
AGENT_UUID=
AGENT_SECRET=

# ── Panel connection ───────────────────────────────────────────────────────────
# Display name shown in the bot admin panel
PANEL_NAME=My Iran Panel

# 3x-ui panel host (usually 127.0.0.1 if installed on same machine)
PANEL_HOST=127.0.0.1

# 3x-ui panel port (default 2053)
PANEL_PORT=2053

# 3x-ui panel URL path prefix (empty or e.g. xui)
PANEL_PATH=

# 3x-ui login username
PANEL_USERNAME=admin

# 3x-ui login password
PANEL_PASSWORD=

# ── Agent name (used for display in bot admin) ────────────────────────────────
AGENT_NAME=Iran Agent 1

# ── Timing ────────────────────────────────────────────────────────────────────
# Heartbeat interval in seconds (how often to ping the bot API)
HEARTBEAT_INTERVAL=60

# Panel test interval in seconds (how often to test 3x-ui login)
PANEL_TEST_INTERVAL=300

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15

# ── Optional proxy for outbound traffic to foreign server ─────────────────────
# Leave empty to use direct connection
# Example: http://127.0.0.1:10809
PROXY_URL=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=agent.log
